# Kopiraj v .env in izpolni — NE committaj prave ključe v .env.example
# Zaženi z Node 22 LTS (.nvmrc) — Node 24 pogosto zlomi prijavo (better-sqlite3).

PORT=3001
CLIENT_URL=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-string

USE_MOCK_AUTH=true

# Opcijsko: uporabniška imena (ločena z vejico), ki lahko urejajo naročila tudi če niso ustvarjalec
# ADMIN_USERNAMES=marko,admin

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discogs Developer (obvezno za prave API klice)
# Lokalno callback: http://localhost:5173/auth/discogs/callback
# Railway: https://tvoja-domena.up.railway.app/auth/discogs/callback
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# E-pošta (ponastavitev gesla + obvestila). Brez SMTP se v dev načinu vse izpiše v konzolo strežnika.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=DSO <noreply@example.com>

# Railway / produkcija (primer):
# NODE_ENV=production
# CLIENT_URL=https://dso-production.up.railway.app
# SESSION_SECRET=<dolg-nakljucni-niz>
# USE_MOCK_AUTH=false
#
# Trajna baza na Railwayu (OBVEZNO — brez tega se računi izbrišejo ob redeployu):
# 1. Railway → tvoja storitev → Volumes → Add Volume
# 2. Mount path: /app/data
# 3. Redeploy (RAILWAY_VOLUME_MOUNT_PATH se nastavi samodejno)
# Opcijsko ročno: DATA_DIR=/app/data
